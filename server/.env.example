# ============================================================
# 掼蛋服务端环境变量模板
# 复制此文件为 .env 并填写真实值，不要提交 .env 到版本控制
# ============================================================

# 服务器
NODE_ENV=development
PORT=3001

# 前端地址（CORS 白名单）
# 开发：http://localhost:3000
# 生产：https://your-domain.com
CLIENT_URL=http://localhost:3000

# JWT 密钥（生产环境请使用 64 位以上随机字符串）
# 生成命令：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# 数据库路径（相对于项目根目录）
DB_PATH=../data/guandan.db

# 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# 游戏参数（可选，覆盖默认值）
# TURN_TIMEOUT=30
# RECONNECT_TIMEOUT=60
# MATCHMAKING_TIMEOUT=120
